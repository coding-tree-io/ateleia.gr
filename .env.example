# Form.taxi endpoint for the public contact form.
# It must be registered in Form.taxi to deliver to the same inbox used by the
# mailto contact item in src/content/therapy-practice-website-content.ts.
PUBLIC_CONTACT_FORM_ENDPOINT=https://form.taxi/s/tb10t33e

# Optional Decap CMS build-time overrides.
DECAP_REPOSITORY=coding-tree-io/ateleia.gr
DECAP_BRANCH=main
DECAP_SITE_URL=https://coding-tree-io.github.io/ateleia.gr/
DECAP_LOGO_URL=https://decapbridge.com/decapcms-with-bridge.svg

# Optional DecapBridge overrides. These defaults already match the configured site.
DECAPBRIDGE_BASE_URL=https://auth.decapbridge.com
DECAPBRIDGE_AUTH_ENDPOINT=/sites/1731d52f-3a01-4de9-8c6f-98598c438922/pkce
DECAPBRIDGE_AUTH_TOKEN_ENDPOINT=/sites/1731d52f-3a01-4de9-8c6f-98598c438922/token
DECAPBRIDGE_GATEWAY_URL=https://gateway.decapbridge.com
