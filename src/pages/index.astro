---
import { PaintedEdgeDivider } from '@/components/decorative/ArtShapes';
import { Announcements } from '@/components/sections/Announcements';
import { About } from '@/components/sections/About';
import ContactSection from '@/components/sections/ContactSection.astro';
import { Footer } from '@/components/sections/Footer';
import { Hero } from '@/components/sections/Hero';
import SiteHeader from '@/components/sections/SiteHeader.astro';
import { Services } from '@/components/sections/Services';
import { WhatIs } from '@/components/sections/WhatIs';
import { WhoIsItFor } from '@/components/sections/WhoIsItFor';
import {
  createOrganizationStructuredData,
  createWebSiteStructuredData,
  getRobotsDirective,
} from '@/config/site-metadata';
import { getAnnouncements } from '@/content/announcements';
import { therapyPracticeWebsiteContent } from '@/content/therapy-practice-website-content';
import { getServices } from '@/content/services';
import PublicDocumentLayout from '@/layouts/PublicDocumentLayout.astro';

const topDividerClassName = 'therapy-illustrated-section-divider therapy-illustrated-section-divider-after-hero';
const sectionDividerClassName = 'therapy-illustrated-section-divider therapy-illustrated-section-divider-standard';
const sectionDividerInvertedClassName =
  'therapy-illustrated-section-divider therapy-illustrated-section-divider-inverted';
const announcements = (await getAnnouncements()).slice(0, 2);
const hasAnnouncements = announcements.length > 0;
const services = await getServices();
const structuredData = [createOrganizationStructuredData(), createWebSiteStructuredData()];
const { seo } = therapyPracticeWebsiteContent;
---

<PublicDocumentLayout
  pageTitle={seo.pageTitle}
  pageDescription={seo.pageDescription}
  canonicalPath=""
  robots={getRobotsDirective()}
  openGraphTitle={seo.openGraphTitle}
  openGraphDescription={seo.openGraphDescription}
  structuredData={structuredData}
  htmlClassName="hero-in-view"
  includeCodingTreeAttributionScript
>
  <div class="min-h-screen overflow-x-clip bg-background font-sans text-foreground">
    <SiteHeader />

    <main class="relative overflow-x-clip overflow-y-visible">
      <Hero />
      <PaintedEdgeDivider className={topDividerClassName} />

      <div id="what-is">
        <WhatIs />
      </div>
      <PaintedEdgeDivider className={sectionDividerInvertedClassName} />

      <div id="who-is-it-for">
        <WhoIsItFor />
      </div>
      <PaintedEdgeDivider className={sectionDividerClassName} />

      <About />
      <PaintedEdgeDivider className={sectionDividerInvertedClassName} />

      <Services services={services} client:visible />
      <PaintedEdgeDivider className={sectionDividerClassName} />

      {hasAnnouncements ? (
        <>
          <Announcements announcements={announcements} />
          <PaintedEdgeDivider className={sectionDividerInvertedClassName} />
        </>
      ) : null}

      <ContactSection />
    </main>

    <Footer />
  </div>
</PublicDocumentLayout>
