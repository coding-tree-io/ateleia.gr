---
import { createProjectRelativeUrl } from '@/config/site-branding';

const adminConfigUrl = createProjectRelativeUrl('admin/config.yml');
const faviconSvgUrl = createProjectRelativeUrl('favicon.svg');
const faviconIcoUrl = createProjectRelativeUrl('favicon.ico');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Ateleia CMS</title>
    <link rel="icon" type="image/svg+xml" href={faviconSvgUrl} />
    <link rel="icon" href={faviconIcoUrl} />
    <link rel="cms-config-url" type="text/yaml" href={adminConfigUrl} />
    <style is:inline>
      :root {
        color-scheme: light;
        font-family: "Nunito", "Noto Sans", system-ui, sans-serif;
        background: #f6efe9;
        color: #3d3534;
      }

      body {
        margin: 0;
      }

      .cms-loading {
        display: grid;
        min-height: 100vh;
        place-items: center;
        padding: 2rem;
        background:
          radial-gradient(circle at top right, rgba(199, 57, 46, 0.14), transparent 32%),
          linear-gradient(180deg, #f8f1eb 0%, #f3ebe5 100%);
      }

      .cms-loading__panel {
        max-width: 36rem;
        border: 1px solid rgba(61, 53, 52, 0.12);
        border-radius: 1.5rem;
        background: rgba(255, 255, 255, 0.88);
        box-shadow: 0 18px 40px rgba(61, 53, 52, 0.08);
        padding: 1.5rem;
      }

      .cms-loading__eyebrow {
        margin: 0 0 0.5rem;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #c7392e;
      }

      .cms-loading__title {
        margin: 0;
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: clamp(2rem, 5vw, 2.8rem);
        line-height: 1;
      }

      .cms-loading__body,
      .cms-loading__note {
        margin: 0.9rem 0 0;
        line-height: 1.65;
      }

      .cms-loading__note {
        border-radius: 1rem;
        background: rgba(199, 57, 46, 0.08);
        padding: 0.85rem 1rem;
      }
    </style>
  </head>
  <body>
    <main class="cms-loading">
      <div class="cms-loading__panel">
        <p class="cms-loading__eyebrow">Admin</p>
        <h1 class="cms-loading__title">Ateleia CMS</h1>
        <p class="cms-loading__body">
          Local development uses the Decap proxy backend and does not require DecapBridge or
          Google login. The deployed GitHub Pages admin uses DecapBridge PKCE when configured
          online.
        </p>
        <p class="cms-loading__note">
          The production login URL for this GitHub Pages project site is
          `https://coding-tree-io.github.io/ateleia.gr/admin/index.html`.
        </p>
      </div>
    </main>
    <script src="https://unpkg.com/decap-cms@3.10.1/dist/decap-cms.js"></script>
  </body>
</html>
