---
import '@fontsource/nunito/400.css';
import '@fontsource/nunito/500.css';
import '@fontsource/nunito/600.css';
import '@fontsource/nunito/700.css';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/700.css';
import '@fontsource/cormorant-garamond/400-italic.css';
import '@fontsource/cormorant-garamond/500-italic.css';

import {
  createProjectRelativeUrl,
} from '@/config/site-branding';

const adminConfigUrl = createProjectRelativeUrl('admin/config.yml');
const faviconSvgUrl = createProjectRelativeUrl('favicon.svg');
const faviconIcoUrl = createProjectRelativeUrl('favicon.ico');
const adminStyleUrl = createProjectRelativeUrl('admin/admin.css');
const previewStyleUrl = createProjectRelativeUrl('admin/preview.css');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Ateleia CMS</title>
    <link rel="stylesheet" href={adminStyleUrl} />
    <link rel="icon" type="image/svg+xml" href={faviconSvgUrl} />
    <link rel="icon" href={faviconIcoUrl} />
    <link rel="cms-config-url" type="text/yaml" href={adminConfigUrl} />
  </head>
  <body>
    <script is:inline>
      window.CMS_MANUAL_INIT = true;
    </script>
    <script src="https://unpkg.com/decap-cms@3.10.1/dist/decap-cms.js"></script>
    <script is:inline define:vars={{ adminStyleUrl, previewStyleUrl }}>
      const registerServicesEditor = () => {
        if (!window.CMS || !window.createClass || !window.h || !window.initCMS) {
          window.setTimeout(registerServicesEditor, 30);
          return;
        }

        const h = window.h;
        const numberWords = {
          feminine: {
            0: 'μηδέν',
            1: 'μία',
            2: 'δύο',
            3: 'τρεις',
            4: 'τέσσερις',
            5: 'πέντε',
            6: 'έξι',
            7: 'επτά',
            8: 'οκτώ',
            9: 'εννέα',
            10: 'δέκα',
          },
          neuter: {
            0: 'μηδέν',
            1: 'ένα',
            2: 'δύο',
            3: 'τρία',
            4: 'τέσσερα',
            5: 'πέντε',
            6: 'έξι',
            7: 'επτά',
            8: 'οκτώ',
            9: 'εννέα',
            10: 'δέκα',
          },
        };
        const countLabels = [
          {
            aliases: ['υπηρεσια', 'υπηρεσιες'],
            singular: 'υπηρεσία',
            plural: 'υπηρεσίες',
            gender: 'feminine',
          },
          {
            aliases: ['παραγραφος', 'παραγραφοι'],
            singular: 'παράγραφος',
            plural: 'παράγραφοι',
            gender: 'feminine',
          },
          {
            aliases: ['ερωτηση', 'ερωτησεις', 'συχνες ερωτησεις'],
            singular: 'ερώτηση',
            plural: 'συχνές ερωτήσεις',
            gender: 'feminine',
          },
          {
            aliases: ['στοιχειο', 'στοιχεια'],
            singular: 'στοιχείο',
            plural: 'στοιχεία',
            gender: 'neuter',
          },
          {
            aliases: ['στοιχειο λιστας', 'στοιχεια λιστας'],
            singular: 'στοιχείο λίστας',
            plural: 'στοιχεία λίστας',
            gender: 'neuter',
          },
          {
            aliases: ['στοιχειο επικοινωνιας', 'στοιχεια επικοινωνιας'],
            singular: 'στοιχείο επικοινωνίας',
            plural: 'στοιχεία επικοινωνίας',
            gender: 'neuter',
          },
          {
            aliases: ['τι να περιμενετε'],
            singular: 'στοιχείο',
            plural: 'στοιχεία',
            gender: 'neuter',
          },
        ];

        const toArray = (value) => {
          if (!value) {
            return [];
          }

          if (typeof value.toJS === 'function') {
            return value.toJS();
          }

          return Array.isArray(value) ? value : [];
        };
        const toPlainObject = (value) => JSON.parse(JSON.stringify(value ?? {}));
        const deepMerge = (target, source) => {
          Object.entries(source).forEach(([key, value]) => {
            if (Array.isArray(value)) {
              target[key] = value.slice();
              return;
            }

            if (value && typeof value === 'object') {
              const nextTarget =
                target[key] && typeof target[key] === 'object' && !Array.isArray(target[key])
                  ? target[key]
                  : {};
              target[key] = deepMerge(nextTarget, value);
              return;
            }

            target[key] = value;
          });

          return target;
        };
        const normalizeForMatch = (value) =>
          String(value ?? '')
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '')
            .toLowerCase()
            .replace(/\s+/g, ' ')
            .trim();
        const toGreekCount = (count, gender) => numberWords[gender]?.[count] ?? String(count);
        const translateRenderedText = (value) => {
          const normalized = normalizeForMatch(value);
          const directReplacements = {
            'add υπηρεσια': 'Προσθέστε Υπηρεσία',
            'add παραγραφος': 'Προσθέστε Παράγραφο',
            'add ερωτηση': 'Προσθέστε Ερώτηση',
            'add στοιχειο': 'Προσθέστε Στοιχείο',
            'add στοιχεια': 'Προσθέστε Στοιχείο',
            'προσθεστε υπηρεσια': 'Προσθέστε Υπηρεσία',
            'προσθεστε παραγραφος': 'Προσθέστε Παράγραφο',
            'προσθεστε ερωτηση': 'Προσθέστε Ερώτηση',
            'προσθεστε στοιχειο': 'Προσθέστε Στοιχείο',
            'προσθεστε στοιχεια': 'Προσθέστε Στοιχείο',
            '1 τι να περιμενετε': 'ένα στοιχείο',
            '2 τι να περιμενετε': 'δύο στοιχεία',
          };

          if (directReplacements[normalized]) {
            return directReplacements[normalized];
          }

          const countMatch = normalized.match(/^(\d+)\s+(.+)$/);
          if (!countMatch) {
            return value;
          }

          const count = Number(countMatch[1]);
          const noun = countMatch[2];
          const labelDefinition = countLabels.find(({ aliases }) => aliases.includes(noun));
          if (!labelDefinition) {
            return value;
          }

          return `${toGreekCount(count, labelDefinition.gender)} ${
            count === 1 ? labelDefinition.singular : labelDefinition.plural
          }`;
        };
        const localizeAdminText = () => {
          const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
            acceptNode(node) {
              if (!node.textContent || !node.textContent.trim()) {
                return NodeFilter.FILTER_REJECT;
              }

              const parentElement = node.parentElement;
              if (!parentElement || parentElement.closest('script, style')) {
                return NodeFilter.FILTER_REJECT;
              }

              return NodeFilter.FILTER_ACCEPT;
            },
          });
          const textNodes = [];

          while (walker.nextNode()) {
            textNodes.push(walker.currentNode);
          }

          textNodes.forEach((textNode) => {
            const localizedText = translateRenderedText(textNode.textContent);
            if (localizedText !== textNode.textContent) {
              textNode.textContent = localizedText;
            }
          });

          document.querySelectorAll('[aria-label]').forEach((element) => {
            const currentLabel = element.getAttribute('aria-label');
            const localizedLabel = translateRenderedText(currentLabel);
            if (localizedLabel !== currentLabel) {
              element.setAttribute('aria-label', localizedLabel);
            }
          });
        };
        const installAdminTextLocalizer = () => {
          let isScheduled = false;
          const scheduleLocalization = () => {
            if (isScheduled) {
              return;
            }

            isScheduled = true;
            requestAnimationFrame(() => {
              isScheduled = false;
              localizeAdminText();
            });
          };

          new MutationObserver(scheduleLocalization).observe(document.body, {
            childList: true,
            subtree: true,
            characterData: true,
          });

          scheduleLocalization();
        };
        const registerGreekLocale = () => {
          const englishLocale = toPlainObject(window.CMS.getLocale('en'));
          const greekLocale = deepMerge(englishLocale, {
            app: {
              header: {
                content: 'Περιεχόμενο',
                media: 'Πολυμέσα',
                quickAdd: 'Γρήγορη προσθήκη',
              },
            },
            collection: {
              sidebar: {
                collections: 'Συλλογές',
                allCollections: 'Όλες οι συλλογές',
                searchAll: 'Αναζήτηση σε όλα',
                searchIn: 'Αναζήτηση σε',
              },
              collectionTop: {
                newButton: 'Προσθέστε %{collectionLabel}',
                sortBy: 'Ταξινόμηση κατά',
                viewAs: 'Προβολή ως',
                viewAsList: 'Προβολή λίστας',
                viewAsGrid: 'Προβολή πλέγματος',
              },
              entries: {
                loadingEntries: 'Φόρτωση καταχωρίσεων...',
                cachingEntries: 'Προετοιμασία καταχωρίσεων...',
                noEntries: 'Δεν υπάρχουν καταχωρίσεις',
              },
            },
            editor: {
              editor: {
                loadingEntry: 'Φόρτωση καταχώρισης...',
              },
              editorControl: {
                field: {
                  optional: 'προαιρετικό',
                },
              },
              editorControlPane: {
                widget: {
                  rangeCount:
                    'Το πεδίο %{fieldLabel} πρέπει να περιλαμβάνει από %{minCount} έως %{maxCount} στοιχεία.',
                  rangeCountExact:
                    'Το πεδίο %{fieldLabel} πρέπει να περιλαμβάνει ακριβώς %{count} στοιχεία.',
                  rangeMin:
                    'Το πεδίο %{fieldLabel} πρέπει να περιλαμβάνει τουλάχιστον %{minCount} στοιχεία.',
                  rangeMax:
                    'Το πεδίο %{fieldLabel} πρέπει να περιλαμβάνει έως %{maxCount} στοιχεία.',
                },
              },
              editorToolbar: {
                publishAndCreateNew: 'Δημοσίευση και νέα καταχώριση',
                deleteUnpublishedChanges: 'Διαγραφή αδημοσίευτων αλλαγών',
                deleteUnpublishedEntry: 'Διαγραφή αδημοσίευτης καταχώρισης',
                deletePublishedEntry: 'Διαγραφή δημοσιευμένης καταχώρισης',
                deleteEntry: 'Διαγραφή καταχώρισης',
              },
              editorWidgets: {
                list: {
                  add: 'Προσθέστε %{item}',
                  addType: 'Προσθέστε %{item}',
                },
                object: {
                  expand: 'Ανάπτυξη',
                  collapse: 'Σύμπτυξη',
                },
                image: {
                  addMore: 'Προσθέστε περισσότερες εικόνες',
                  remove: 'Αφαίρεση εικόνας',
                  removeAll: 'Αφαίρεση όλων των εικόνων',
                },
                file: {
                  addMore: 'Προσθέστε περισσότερα αρχεία',
                  remove: 'Αφαίρεση αρχείου',
                  removeAll: 'Αφαίρεση όλων των αρχείων',
                },
              },
            },
            ui: {
              settingsDropdown: {
                account: 'Επιλογές λογαριασμού',
              },
              toast: {
                entrySaved: 'Η καταχώριση αποθηκεύτηκε',
                entryPublished: 'Η καταχώριση δημοσιεύτηκε',
                entryUnpublished: 'Η καταχώριση αποδημοσιεύτηκε',
                entryUpdated: 'Η κατάσταση ενημερώθηκε',
              },
            },
          });

          window.CMS.registerLocale('el', greekLocale);
        };
        const joinNonEmpty = (value, separator = ' · ') => toArray(value).filter(Boolean).join(separator);
        const toText = (value, fallback = '') => {
          if (typeof value === 'string') {
            const normalized = value.trim();
            return normalized.length > 0 ? normalized : fallback;
          }

          if (value === null || value === undefined) {
            return fallback;
          }

          const normalized = String(value).trim();
          return normalized.length > 0 ? normalized : fallback;
        };
        const getEntryText = (entry, path, fallback = '') => toText(entry?.getIn?.(path), fallback);
        const announcementKindLabelByValue = {
          workshop: 'Εργαστήριο',
          group: 'Ομάδα',
          announcement: 'Ανακοίνωση',
        };
        const announcementKindClassByValue = {
          workshop: 'decap-announcements-preview__badge--workshop',
          group: 'decap-announcements-preview__badge--group',
          announcement: 'decap-announcements-preview__badge--announcement',
        };
        const resolveHomePagePreviewKind = (entry) => {
          const routeHash = toText(window?.parent?.location?.hash).toLowerCase();
          if (routeHash.includes('/entries/services')) {
            return 'services';
          }

          if (routeHash.includes('/entries/announcements')) {
            return 'announcements';
          }

          if (routeHash.includes('/entries/site-content')) {
            return 'site-content';
          }

          const hasSeoField = entry?.getIn?.(['data', 'seo']) !== undefined;
          const hasAnnouncementsField = entry?.getIn?.(['data', 'announcements']) !== undefined;
          const hasServicesField = entry?.getIn?.(['data', 'services']) !== undefined;

          if (hasSeoField) {
            return 'site-content';
          }

          if (hasAnnouncementsField) {
            return 'announcements';
          }

          if (hasServicesField) {
            return 'services';
          }

          const entryPath = toText(entry?.get?.('path')).toLowerCase();
          const entrySlug = toText(entry?.get?.('slug')).toLowerCase();

          if (entryPath.includes('services.json') || entrySlug === 'services') {
            return 'services';
          }

          if (entryPath.includes('announcements.json') || entrySlug === 'announcements') {
            return 'announcements';
          }

          return 'site-content';
        };

        const SiteContentPreview = window.createClass({
          render() {
            const entryData = this.props.entry.get('data');
            const navigation = entryData.get('navigation');
            const hero = entryData.get('hero');
            const contact = entryData.get('contact');
            const contactItems = toArray(contact?.get?.('contactItems')).filter(
              (item) => toText(item?.value).length > 0,
            );
            const overviewBlocks = [
              {
                key: 'what-is',
                label: 'Τι είναι',
                title: getEntryText(entryData, ['whatIs', 'title'], 'Τι είναι η Θεραπεία μέσω τέχνης'),
                summary: getEntryText(entryData, ['whatIs', 'practiceNote'], 'Σύντομη πρακτική σημείωση.'),
              },
              {
                key: 'who-is-it-for',
                label: 'Σε ποιους απευθύνεται',
                title: getEntryText(entryData, ['whoIsItFor', 'title'], 'Σε ποιους απευθύνεται'),
                summary: joinNonEmpty(entryData.getIn(['whoIsItFor', 'items'])) || 'Στόχος κοινού και βασικές ενδείξεις.',
              },
              {
                key: 'about',
                label: 'Σχετικά',
                title: getEntryText(entryData, ['about', 'title'], 'Σχετικά'),
                summary:
                  getEntryText(entryData, ['about', 'pullQuote'], '') ||
                  getEntryText(entryData, ['about', 'approach', 'description'], 'Περιγραφή θεραπευτικής προσέγγισης.'),
              },
              {
                key: 'contact',
                label: 'Επικοινωνία',
                title: getEntryText(entryData, ['contact', 'title'], 'Επικοινωνία'),
                summary: getEntryText(entryData, ['contact', 'description'], 'Περιγραφή επικοινωνίας.'),
              },
            ];

            return h('section', { className: 'decap-site-preview' }, [
              h('div', { className: 'decap-site-preview__shell', key: 'shell' }, [
                h('header', { className: 'decap-site-preview__header', key: 'header' }, [
                  h('p', { className: 'decap-site-preview__eyebrow', key: 'eyebrow' }, 'ΠΡΟΕΠΙΣΚΟΠΗΣΗ ΑΡΧΙΚΗΣ'),
                  h('h1', { className: 'decap-site-preview__title', key: 'title' }, getEntryText(entryData, ['brandName'], 'Ατέλεια')),
                  h(
                    'p',
                    { className: 'decap-site-preview__subtitle', key: 'subtitle' },
                    getEntryText(entryData, ['brandSubtitle'], 'Θεραπεία μέσω τέχνης'),
                  ),
                  h(
                    'div',
                    { className: 'decap-site-preview__nav-chips', key: 'navigation' },
                    [
                      getEntryText(navigation, ['whatIs'], 'Τι είναι'),
                      getEntryText(navigation, ['whoIsItFor'], 'Σε ποιους απευθύνεται'),
                      getEntryText(navigation, ['about'], 'Σχετικά'),
                      getEntryText(navigation, ['services'], 'Υπηρεσίες'),
                      getEntryText(navigation, ['contact'], 'Επικοινωνία'),
                    ].map((navigationLabel, index) =>
                      h('span', { className: 'decap-site-preview__nav-chip', key: `nav-chip-${index}` }, navigationLabel),
                    ),
                  ),
                ]),
                h('article', { className: 'decap-site-preview__hero-card', key: 'hero' }, [
                  h('p', { className: 'decap-site-preview__hero-kicker', key: 'hero-kicker' }, 'Hero'),
                  h(
                    'h2',
                    { className: 'decap-site-preview__hero-headline', key: 'hero-headline' },
                    getEntryText(hero, ['headline'], 'Θεραπεία μέσω τέχνης'),
                  ),
                  h(
                    'p',
                    { className: 'decap-site-preview__hero-copy', key: 'hero-copy' },
                    getEntryText(hero, ['subheadline'], 'Περιγραφή εισαγωγικού hero.'),
                  ),
                  h('div', { className: 'decap-site-preview__hero-actions', key: 'hero-actions' }, [
                    h('span', { className: 'decap-site-preview__hero-action decap-site-preview__hero-action--primary', key: 'hero-primary' }, getEntryText(hero, ['primaryCta'], 'Κλείστε ραντεβού')),
                    h('span', { className: 'decap-site-preview__hero-action', key: 'hero-secondary' }, getEntryText(hero, ['secondaryCta'], 'Στείλτε μήνυμα')),
                  ]),
                ]),
                h(
                  'div',
                  { className: 'decap-site-preview__overview-grid', key: 'overview-grid' },
                  overviewBlocks.map((overviewBlock) =>
                    h('article', { className: 'decap-site-preview__overview-card', key: overviewBlock.key }, [
                      h('p', { className: 'decap-site-preview__overview-label', key: `${overviewBlock.key}-label` }, overviewBlock.label),
                      h('h3', { className: 'decap-site-preview__overview-title', key: `${overviewBlock.key}-title` }, overviewBlock.title),
                      h('p', { className: 'decap-site-preview__overview-copy', key: `${overviewBlock.key}-summary` }, overviewBlock.summary),
                    ]),
                  ),
                ),
                h('section', { className: 'decap-site-preview__contact-strip', key: 'contact-strip' }, [
                  h('p', { className: 'decap-site-preview__contact-strip-title', key: 'contact-strip-title' }, 'Στοιχεία επικοινωνίας'),
                  h(
                    'div',
                    { className: 'decap-site-preview__contact-strip-items', key: 'contact-strip-items' },
                    contactItems.length > 0
                      ? contactItems.slice(0, 3).map((item, itemIndex) =>
                          h('p', { className: 'decap-site-preview__contact-strip-item', key: `contact-item-${itemIndex}` }, `${toText(item.label, 'Στοιχείο')}: ${item.value}`),
                        )
                      : [h('p', { className: 'decap-site-preview__contact-strip-item', key: 'contact-item-empty' }, 'Προσθέστε στοιχεία επικοινωνίας για την προεπισκόπηση.')],
                  ),
                ]),
              ]),
            ]);
          },
        });

        const ServicesPreview = window.createClass({
          render() {
            const services = toArray(this.props.entry.getIn(['data', 'services']));

            return h('section', { className: 'decap-services-preview' }, [
              h('div', { className: 'decap-services-preview__shell', key: 'shell' }, [
                h('div', { className: 'decap-services-preview__intro', key: 'intro' }, [
                  h('p', { className: 'decap-services-preview__eyebrow', key: 'eyebrow' }, 'ΠΡΟΕΠΙΣΚΟΠΗΣΗ ΕΝΟΤΗΤΑΣ'),
                  h('h1', { className: 'decap-services-preview__title', key: 'title' }, 'Υπηρεσίες'),
                  h(
                    'p',
                    { className: 'decap-services-preview__lead', key: 'lead' },
                    'Η προεπισκόπηση ακολουθεί την αισθητική των καρτών της ζωντανής σελίδας και δείχνει πώς θα διαβαστεί η ενότητα όταν δημοσιευτεί.',
                  ),
                ]),
                h(
                  'div',
                  { className: 'decap-services-preview__grid', key: 'grid' },
                  services.length > 0
                    ? services.map((service, index) => {
                        const serviceMeta = [service.format, service.duration].filter(Boolean).join(' / ');
                        const audienceSummary = joinNonEmpty(service.idealFor);
                        const supportItems = toArray(service.whatToExpect).filter(Boolean);

                        return h(
                          'article',
                          {
                            className: 'decap-services-preview__card',
                            key: `${service.title ?? 'service'}-${index}`,
                          },
                          [
                            h('span', { className: 'decap-services-preview__card-glow', key: 'glow', 'aria-hidden': 'true' }),
                            h('h2', { className: 'decap-services-preview__card-title', key: 'title' }, service.title || 'Νέα υπηρεσία'),
                            h(
                              'p',
                              { className: 'decap-services-preview__card-copy', key: 'description' },
                              service.description || 'Σύντομη περιγραφή υπηρεσίας.',
                            ),
                            h('div', { className: 'decap-services-preview__facts', key: 'facts' }, [
                              h('div', { className: 'decap-services-preview__fact', key: 'audience' }, [
                                h('span', { className: 'decap-services-preview__fact-icon', key: 'audience-icon', 'aria-hidden': 'true' }, '◎'),
                                h('p', { className: 'decap-services-preview__fact-copy', key: 'audience-copy' }, [
                                  h('strong', { key: 'audience-label' }, 'Σε ποιους απευθύνεται: '),
                                  audienceSummary || 'Σύντομη περιγραφή κοινού.',
                                ]),
                              ]),
                              serviceMeta
                                ? h('div', { className: 'decap-services-preview__fact', key: 'meta' }, [
                                    h('span', { className: 'decap-services-preview__fact-icon', key: 'meta-icon', 'aria-hidden': 'true' }, '◌'),
                                    h('p', { className: 'decap-services-preview__fact-copy decap-services-preview__meta', key: 'meta-copy' }, serviceMeta),
                                  ])
                                : null,
                            ].filter(Boolean)),
                            supportItems.length > 0
                              ? h('div', { className: 'decap-services-preview__support', key: 'support' }, [
                                  h('p', { className: 'decap-services-preview__support-title', key: 'support-title' }, 'ΤΙ ΝΑ ΠΕΡΙΜΕΝΕΤΕ'),
                                  h(
                                    'ul',
                                    { className: 'decap-services-preview__support-list', key: 'support-list' },
                                    supportItems.map((item, itemIndex) =>
                                      h('li', { key: `${item}-${itemIndex}` }, item),
                                    ),
                                  ),
                                ])
                              : null,
                          ].filter(Boolean),
                        );
                      })
                    : [
                        h(
                          'div',
                          { className: 'decap-services-preview__empty', key: 'empty' },
                          'Προσθέστε υπηρεσίες για να εμφανιστεί εδώ η ζωντανή προεπισκόπηση των καρτών.',
                        ),
                      ],
                ),
              ]),
            ]);
          },
        });

        const AnnouncementsPreview = window.createClass({
          render() {
            const announcements = toArray(this.props.entry.getIn(['data', 'announcements']));

            return h('section', { className: 'decap-announcements-preview' }, [
              h('div', { className: 'decap-announcements-preview__shell', key: 'shell' }, [
                h('div', { className: 'decap-announcements-preview__intro', key: 'intro' }, [
                  h('p', { className: 'decap-announcements-preview__eyebrow', key: 'eyebrow' }, 'ΠΡΟΕΠΙΣΚΟΠΗΣΗ ΕΝΟΤΗΤΑΣ'),
                  h('h1', { className: 'decap-announcements-preview__title', key: 'title' }, 'Νέα & Ανακοινώσεις'),
                  h(
                    'p',
                    { className: 'decap-announcements-preview__lead', key: 'lead' },
                    'Η προεπισκόπηση εμφανίζει τις δημοσιευμένες ανακοινώσεις όπως διαβάζονται στην αρχική σελίδα.',
                  ),
                ]),
                h(
                  'div',
                  { className: 'decap-announcements-preview__grid', key: 'grid' },
                  announcements.length > 0
                    ? announcements.map((announcement, index) => {
                        const announcementKind = toText(announcement.kind, 'announcement');
                        const announcementKindLabel =
                          announcementKindLabelByValue[announcementKind] ??
                          announcementKindLabelByValue.announcement;
                        const announcementKindClass =
                          announcementKindClassByValue[announcementKind] ??
                          announcementKindClassByValue.announcement;
                        const shouldShowCallToAction = toText(announcement.callToActionLabel).length > 0;

                        return h(
                          'article',
                          {
                            className: 'decap-announcements-preview__card',
                            key: `${announcement.title ?? 'announcement'}-${index}`,
                          },
                          [
                            h('div', { className: 'decap-announcements-preview__meta', key: 'meta' }, [
                              h(
                                'p',
                                { className: 'decap-announcements-preview__date', key: 'date' },
                                toText(announcement.dateLabel, 'Χωρίς ημερομηνία'),
                              ),
                              h(
                                'span',
                                { className: `decap-announcements-preview__badge ${announcementKindClass}`, key: 'kind' },
                                announcementKindLabel,
                              ),
                            ]),
                            h(
                              'h2',
                              { className: 'decap-announcements-preview__card-title', key: 'title' },
                              toText(announcement.title, 'Νέα ανακοίνωση'),
                            ),
                            h(
                              'p',
                              { className: 'decap-announcements-preview__card-copy', key: 'summary' },
                              toText(announcement.summary, 'Προσθέστε σύντομη περιγραφή για την ανακοίνωση.'),
                            ),
                            shouldShowCallToAction
                              ? h(
                                  'p',
                                  { className: 'decap-announcements-preview__cta', key: 'cta' },
                                  `${announcement.callToActionLabel} ↗`,
                                )
                              : null,
                          ].filter(Boolean),
                        );
                      })
                    : [
                        h(
                          'div',
                          { className: 'decap-announcements-preview__empty', key: 'empty' },
                          'Προσθέστε ανακοινώσεις για να εμφανιστεί η προεπισκόπηση.',
                        ),
                      ],
                ),
              ]),
            ]);
          },
        });
        const HomePageCollectionPreview = window.createClass({
          render() {
            const previewKind = resolveHomePagePreviewKind(this.props.entry);

            if (previewKind === 'services') {
              return h(ServicesPreview, this.props);
            }

            if (previewKind === 'announcements') {
              return h(AnnouncementsPreview, this.props);
            }

            return h(SiteContentPreview, this.props);
          },
        });

        registerGreekLocale();
        window.CMS.registerPreviewStyle(adminStyleUrl);
        window.CMS.registerPreviewStyle(previewStyleUrl);
        window.CMS.registerPreviewTemplate('homepage', HomePageCollectionPreview);
        window.CMS.registerPreviewTemplate('site-content', HomePageCollectionPreview);
        window.CMS.registerPreviewTemplate('services', HomePageCollectionPreview);
        window.CMS.registerPreviewTemplate('announcements', HomePageCollectionPreview);
        window.initCMS({ config: { locale: 'el' } });
        installAdminTextLocalizer();
      };

      registerServicesEditor();
    </script>
  </body>
</html>
