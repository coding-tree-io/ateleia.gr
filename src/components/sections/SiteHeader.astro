---
import { buttonVariants } from '@/components/ui/button';
import { cn } from '@/lib/utils';
import { createLogoImageUrl } from '@/config/site-branding';
import { therapyPracticeWebsiteContent } from '@/content/therapy-practice-website-content';
import MobileNavigationMenu from '@/components/sections/MobileNavigationMenu.astro';
import { ThreadedAlphaWordmark } from '@/components/brand/ThreadedAlphaWordmark';

const {
  brandName,
  brandSubtitle,
  navigationItems,
  hero: { primaryCta },
} = therapyPracticeWebsiteContent;

const logoImageUrl = createLogoImageUrl();

const desktopBookingButtonClassName = cn(
  buttonVariants({ size: 'lg' }),
  'therapy-primary-call-to-action px-6 opacity-100 transition-[opacity,transform] duration-300 motion-reduce:transition-none md:[.hero-in-view_&]:pointer-events-none md:[.hero-in-view_&]:-translate-y-1 md:[.hero-in-view_&]:opacity-0',
);
---

<header class="sticky top-0 z-50 border-b border-border/45 bg-background/90 shadow-sm">
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-3.5 sm:px-6 md:px-10">
    <a href="#hero" class="group flex min-h-11 min-w-0 items-center gap-3 py-0.5 md:shrink-0" aria-label="Αρχική">
      <img
        src={logoImageUrl}
        alt={`Λογότυπο ${brandName}`}
        class="h-10 w-16 shrink-0 rounded-lg border border-border/60 bg-card/85 object-contain px-1 shadow-sm"
      />
      <div class="min-w-0">
        <ThreadedAlphaWordmark className="text-xl sm:text-2xl" />
        <span class="mt-2 hidden truncate text-[11px] tracking-[0.12em] text-muted-foreground sm:block">
          {brandSubtitle}
        </span>
      </div>
    </a>

    <nav class="hidden min-w-0 flex-1 items-center justify-center gap-7 md:flex md:pl-3" aria-label="Κύρια πλοήγηση">
      {navigationItems.map((navigationItem) => (
        <a
          href={navigationItem.href}
          class="therapy-header-navigation-link"
        >
          {navigationItem.label}
        </a>
      ))}
    </nav>

    <div class="hidden overflow-hidden transition-[width] duration-300 motion-reduce:transition-none md:flex md:w-[14rem] md:shrink-0 md:justify-end md:[.hero-in-view_&]:w-[12rem]">
      <a href="#contact" class={desktopBookingButtonClassName} data-header-cta aria-hidden="true" tabindex="-1">
        {primaryCta}
      </a>
    </div>

    <MobileNavigationMenu
      brandName={brandName}
      brandSubtitle={brandSubtitle}
      primaryActionLabel={primaryCta}
      navigationEntries={navigationItems}
    />
  </div>
</header>

<script is:inline>
  (() => {
    const desktopMediaQuery = '(min-width: 768px)';
    const heroSectionId = 'hero';
    const heroInViewClassName = 'hero-in-view';
    const headerCtaSelector = '[data-header-cta]';
    const dialogSelector = '[data-mobile-nav-dialog]';
    const triggerSelector = '[data-mobile-nav-trigger]';
    const closeSelector = '[data-mobile-nav-close]';
    const linkSelector = '[data-mobile-nav-link]';

    const dialogElement = document.querySelector(dialogSelector);
    const triggerElement = document.querySelector(triggerSelector);
    const closeElement = document.querySelector(closeSelector);
    const mobileNavigationLinks = document.querySelectorAll(linkSelector);
    const heroSectionElement = document.getElementById(heroSectionId);
    const headerCtaElement = document.querySelector(headerCtaSelector);

    const applyHeaderCtaAccessibilityState = (shouldHideHeaderCta) => {
      if (!headerCtaElement) {
        return;
      }

      if (shouldHideHeaderCta) {
        headerCtaElement.setAttribute('aria-hidden', 'true');
        headerCtaElement.setAttribute('tabindex', '-1');
        return;
      }

      headerCtaElement.removeAttribute('aria-hidden');
      headerCtaElement.removeAttribute('tabindex');
    };

    const removeHeroVisibilityClass = () => {
      document.documentElement.classList.remove(heroInViewClassName);
    };

    const isHeroCurrentlyVisible = () => {
      if (!heroSectionElement) {
        return false;
      }

      const heroSectionBounds = heroSectionElement.getBoundingClientRect();
      return heroSectionBounds.bottom > 0 && heroSectionBounds.top < window.innerHeight;
    };

    const desktopViewportMediaQueryList = window.matchMedia(desktopMediaQuery);
    let latestHeroVisibilityState = isHeroCurrentlyVisible();

    const syncHeaderCtaVisibilityState = () => {
      const shouldHideHeaderCta = !desktopViewportMediaQueryList.matches || latestHeroVisibilityState;
      applyHeaderCtaAccessibilityState(shouldHideHeaderCta);

      if (!desktopViewportMediaQueryList.matches) {
        removeHeroVisibilityClass();
        return;
      }

      document.documentElement.classList.toggle(heroInViewClassName, latestHeroVisibilityState);
    };

    syncHeaderCtaVisibilityState();

    if (heroSectionElement && 'IntersectionObserver' in window) {
      const heroVisibilityObserver = new IntersectionObserver(
        ([heroVisibilityEntry]) => {
          latestHeroVisibilityState = heroVisibilityEntry?.isIntersecting ?? false;
          syncHeaderCtaVisibilityState();
        },
        { threshold: 0.05 },
      );

      heroVisibilityObserver.observe(heroSectionElement);
    }

    desktopViewportMediaQueryList.addEventListener('change', () => {
      latestHeroVisibilityState = isHeroCurrentlyVisible();
      syncHeaderCtaVisibilityState();

      if (desktopViewportMediaQueryList.matches && dialogElement?.open) {
        dialogElement.close();
      }
    });

    if (!(dialogElement instanceof HTMLDialogElement) || !(triggerElement instanceof HTMLButtonElement)) {
      return;
    }

    const setDocumentScrollLock = (shouldLockScroll) => {
      document.documentElement.classList.toggle('therapy-mobile-navigation-open', shouldLockScroll);
      document.body.classList.toggle('therapy-mobile-navigation-open', shouldLockScroll);
    };

    const syncTriggerState = () => {
      triggerElement.setAttribute('aria-expanded', dialogElement.open ? 'true' : 'false');
    };

    const closeDialog = () => {
      if (!dialogElement.open) {
        return;
      }

      dialogElement.close();
    };

    triggerElement.addEventListener('click', () => {
      if (dialogElement.open) {
        closeDialog();
        return;
      }

      dialogElement.showModal();
      syncTriggerState();
      setDocumentScrollLock(true);
      closeElement instanceof HTMLButtonElement && closeElement.focus();
    });

    closeElement instanceof HTMLButtonElement &&
      closeElement.addEventListener('click', () => {
        closeDialog();
      });

    mobileNavigationLinks.forEach((linkElement) => {
      linkElement.addEventListener('click', () => {
        closeDialog();
      });
    });

    dialogElement.addEventListener('click', (event) => {
      if (event.target === dialogElement) {
        closeDialog();
      }
    });

    dialogElement.addEventListener('close', () => {
      syncTriggerState();
      setDocumentScrollLock(false);
      triggerElement.focus();
    });

    syncTriggerState();
  })();
</script>
