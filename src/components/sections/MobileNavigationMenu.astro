---
import { buttonVariants } from '@/components/ui/button';
import { cn } from '@/lib/utils';

interface NavigationEntry {
  label: string;
  href: string;
}

interface Props {
  brandName: string;
  brandSubtitle: string;
  primaryActionLabel: string;
  navigationEntries: readonly NavigationEntry[];
}

const { brandName, brandSubtitle, primaryActionLabel, navigationEntries } = Astro.props;

const triggerClassName = cn(
  buttonVariants({ variant: 'outline', size: 'icon' }),
  'therapy-mobile-navigation-trigger inline-flex rounded-xl md:hidden',
);
---

<div class="md:hidden">
  <button
    type="button"
    class={triggerClassName}
    aria-label="Άνοιγμα μενού"
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="mobile-navigation-dialog"
    data-mobile-nav-trigger
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="size-5"
      aria-hidden="true"
    >
      <path d="M4 5h16"></path>
      <path d="M4 12h16"></path>
      <path d="M4 19h16"></path>
    </svg>
  </button>

  <dialog
    id="mobile-navigation-dialog"
    class="therapy-mobile-navigation-dialog"
    aria-labelledby="mobile-navigation-title"
    data-mobile-nav-dialog
  >
    <div class="therapy-mobile-navigation-panel">
      <button
        type="button"
        class="therapy-mobile-navigation-close"
        aria-label="Κλείσιμο μενού"
        data-mobile-nav-close
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5"
          aria-hidden="true"
        >
          <path d="m18 6-12 12"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>

      <div class="therapy-mobile-navigation-content">
        <div class="therapy-mobile-navigation-branding">
          <p class="therapy-mobile-navigation-eyebrow">Θεραπεία μέσω τέχνης</p>
          <h2 id="mobile-navigation-title" class="therapy-mobile-navigation-title">{brandName}</h2>
          <p class="therapy-mobile-navigation-subtitle">{brandSubtitle}</p>
        </div>

        <a href="#contact" class="therapy-mobile-navigation-booking-card" data-mobile-nav-link>
          <p class="therapy-mobile-navigation-booking-kicker">ΑΜΕΣΗ ΕΠΙΚΟΙΝΩΝΙΑ</p>
          <p class="therapy-mobile-navigation-booking-title">{primaryActionLabel}</p>
          <p class="therapy-mobile-navigation-booking-note">Συνήθως απάντηση εντός 24 ωρών</p>
          <span class="therapy-mobile-navigation-booking-arrow" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="size-4"
            >
              <path d="m5 12 14 0"></path>
              <path d="m13 6 6 6-6 6"></path>
            </svg>
          </span>
        </a>

        <p class="therapy-mobile-navigation-section-label">Πλοήγηση</p>
        <nav class="mt-3 flex flex-col gap-2" aria-label="Κινητή πλοήγηση">
          {
            navigationEntries.map((navigationEntry) => (
              <a
                href={navigationEntry.href}
                class="therapy-mobile-navigation-link"
                data-mobile-nav-link
              >
                <span class="therapy-mobile-navigation-link-title">{navigationEntry.label}</span>
                <span class="therapy-mobile-navigation-link-arrow" aria-hidden="true">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="size-4"
                  >
                    <path d="M7 17L17 7"></path>
                    <path d="M7 7h10v10"></path>
                  </svg>
                </span>
              </a>
            ))
          }
        </nav>
      </div>
    </div>
  </dialog>
</div>
